model AiSession {
  id          String      @id @default(cuid())
  userId      Int
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId   String      @unique

  messages    AiMessage[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model AiMessage {
  id                     String      @id @default(cuid())

  sessionId              String
  session                AiSession   @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  description            String?

  // Conversation state
  currentStep            String

  // Extracted parameters
  // location               String?
  // startDate              DateTime?
  // endDate                DateTime?
  // travelers              String?
  // budget                 String?
  // experience             String?
  // citizenship            String?
  // passengers             Json?
  passengerPreferences   String?
  parameters_extracted   Json?

  // Trip details
  tripCard               Json?
  tripGuide              Json?

  // Status
  submitted              Boolean     @default(false)
  checkoutRequired       Boolean     @default(false)

  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt

  // Message content
  clientMessage          String
  aiMessage              String

  // Extracted data
  extractedData          Json?

  @@index([sessionId])
}